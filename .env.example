# Host ports for the Docker stack. Copy to .env and adjust if these collide
# with other projects already running on your machine.
#
# The frontend bakes http://127.0.0.1:${BACKEND_PORT}/api at build time, so if
# you change BACKEND_PORT you must rebuild the frontend image:
#   docker compose up -d --build
BACKEND_PORT=8000
FRONTEND_PORT=3000
