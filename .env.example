# Host ports for the Docker stack. Copy to .env and adjust if these collide
# with other projects already running on your machine.
#
# The frontend bakes http://127.0.0.1:${BACKEND_PORT}/api at build time, so if
# you change BACKEND_PORT you must rebuild the frontend image:
#   docker compose up -d --build
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Optional: a GitHub token (classic PAT or fine-grained, read-only) enables repo
# analytics for private repos and raises the API rate limit from 60/hr to 5000/hr.
# Public repos work without it. Get one at https://github.com/settings/tokens
GITHUB_TOKEN=

# Background uptime monitor: seconds between checks of each project's live_url.
MONITOR_INTERVAL=300
